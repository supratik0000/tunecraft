# Copy this file to ".env" and fill in the values.

# Port the API server listens on
PORT=4000

# Secret used to sign login tokens (JWT). Change this to a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# ─────────────────────────────────────────────────────────────
#  Database — Turso (free SQLite-as-a-service) for production.
# ─────────────────────────────────────────────────────────────
# Leave BOTH blank for local development — the server falls back to a
# regular SQLite file at server/data/app.db, so you can run locally
# without signing up for anything.
#
# For production, sign up at https://turso.tech (free), create a database,
# then paste the URL and auth token here.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────
#  AI assistant — choose a FREE provider and paste its key below.
# ─────────────────────────────────────────────────────────────
# Which provider to use: groq | gemini | openrouter | ollama | openai | anthropic
AI_PROVIDER=groq

# Paste your key for the chosen provider into the matching line.
# You only need the ONE that matches AI_PROVIDER above.
#
#  groq        → free, fast (recommended).  Key: https://console.groq.com/keys
GROQ_API_KEY=
#  gemini      → free tier.                 Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
#  openrouter  → has free models.           Key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
#  openai      → paid.                       Key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
#  anthropic   → paid.                       Key: https://console.anthropic.com/
ANTHROPIC_API_KEY=
#  ollama      → runs locally, no key needed (install from https://ollama.com)

# Optional overrides (leave blank to use the provider's sensible default):
#  AI_MODEL=llama-3.3-70b-versatile
#  AI_BASE_URL=               # for any other OpenAI-compatible endpoint
#  AI_API_KEY=                # generic key, overrides the provider-specific one above
AI_MODEL=
